{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "docker-compose",
			"label": "docker-compose: run",
			"dockerCompose": {
				"up": {
					"detached": true,
					"build": true
				},
				"files": ["${workspaceFolder}/docker-compose.yaml"]
			}
		},
		{
			"label": "docker-compose: up",
			"type": "shell",
			"command": "docker compose up -d --build"
		}
	]
}
